{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/marketing/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Inter))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|onClick|onDark|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, onClick, onDark, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Button> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hover|padding|dark|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, hover, padding, dark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactForm'] > JSXAttribute > JSXIdentifier[name!=/^(?:onSubmit|submitLabel|style|key|ref|className|style|children)$/]",
        "message": "<ContactForm> doesn't accept that prop. Declared props: onSubmit, submitLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CTA'] > JSXAttribute > JSXIdentifier[name!=/^(?:overline|title|description|ctaLabel|style|key|ref|className|style|children)$/]",
        "message": "<CTA> doesn't accept that prop. Declared props: overline, title, description, ctaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FAQ'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|style|key|ref|className|style|children)$/]",
        "message": "<FAQ> doesn't accept that prop. Declared props: items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|columns|style|key|ref|className|style|children)$/]",
        "message": "<FeatureGrid> doesn't accept that prop. Declared props: items, columns, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|tagline|columns|note|style|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: brand, tagline, columns, note, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:overline|title|description|ctaLabel|secondaryLabel|image|imageAlt|style|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: overline, title, description, ctaLabel, secondaryLabel, image, imageAlt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|style|key|ref|className|style|children)$/]",
        "message": "<IconCard> doesn't accept that prop. Declared props: icon, title, description, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|placeholder|multiline|rows|error|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, type, placeholder, multiline, rows, error, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navigation'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|links|ctaLabel|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Navigation> doesn't accept that prop. Declared props: brand, links, ctaLabel, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:overline|title|description|align|onDark|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: overline, title, description, align, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|linkLabel|style|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: icon, title, description, linkLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatisticCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|description|onDark|style|key|ref|className|style|children)$/]",
        "message": "<StatisticCard> doesn't accept that prop. Declared props: value, label, description, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|photo|style|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: name, role, photo, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Timeline'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|style|key|ref|className|style|children)$/]",
        "message": "<Timeline> doesn't accept that prop. Declared props: steps, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
