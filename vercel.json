{
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "fortis-anima.com" }], "destination": "https://www.fortis-anima.com/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/Fortis Anima Website.dc.html" },
    { "source": "/sv", "destination": "/sv.html" },
    { "source": "/contact", "destination": "/Contact.dc.html" },
    { "source": "/kontakt", "destination": "/kontakt.html" },
    { "source": "/privacy", "destination": "/Privacy.dc.html" },
    { "source": "/integritet", "destination": "/integritet.html" }
  ]
}
